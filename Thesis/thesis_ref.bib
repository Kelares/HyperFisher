@article{garg_fisher-orthogonal_2026,
  author   = {Garg, Ishir and Kolhe, Neel and Peng, Andy and Gopalam, Rohan},
  title    = {Fisher-Orthogonal Projected Natural Gradient Descent for Continual Learning},
  journal  = {arXiv preprint arXiv:2601.12816},
  year     = {2026},
  doi      = {10.48550/arXiv.2601.12816},
  url      = {http://arxiv.org/abs/2601.12816},
  abstract = {Continual learning aims to enable neural networks to acquire new knowledge on sequential tasks. However, the key challenge in such settings is to learn new tasks without catastrophically forgetting previously learned tasks. We propose the Fisher-Orthogonal Projected Natural Gradient Descent (FOPNG) optimizer, which enforces Fisher-orthogonal constraints on parameter updates to preserve old task performance while learning new tasks.}
}

@article{ly_tutorial_2017,
  author   = {Ly, Alexander and Marsman, Maarten and Verhagen, Josine and Grasman, Raoul and Wagenmakers, Eric-Jan},
  title    = {A Tutorial on Fisher Information},
  journal  = {Journal of Mathematical Psychology},
  volume   = {80},
  pages    = {40--55},
  year     = {2017},
  doi      = {10.48550/arXiv.1705.01064},
  url      = {http://arxiv.org/abs/1705.01064},
  abstract = {In many statistical applications that concern mathematical psychologists, the concept of Fisher information plays an important role. In this tutorial we clarify the concept of Fisher information as it manifests itself across three diﬀerent statistical paradigms.}
}

@article{kimura_information_2022,
  author   = {Kimura, Masanari and Hino, Hideitsu},
  title    = {Information Geometry of Dropout Training},
  journal  = {arXiv preprint arXiv:2206.10936},
  year     = {2022},
  doi      = {10.48550/arXiv.2206.10936},
  abstract = {Dropout is one of the most popular regularization techniques in neural network training... In this paper, several properties of dropout are discussed in a unified manner from the viewpoint of information geometry. We showed that dropout flattens the model manifold and that their regularization performance depends on the amount of the curvature.}
}

