\@writefile{toc}{\contentsline {paragraph}{{Standard hypernetwork --- Split-CIFAR10.}}{19}{paragraph*.17}\protected@file@percent }
\mph@setcol{ii:19}{\mph@nr}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Split-CIFAR10 hypernetwork (5 tasks, 50 epochs per task, AdamW first-task initialisation at $10^{-3}$).} Left: average accuracy (bars show mean over seeds; circles show individual seeds). Right: backward transfer. Methods are sorted by average accuracy on the left panel. \texttt  {Adam} defines the projection-free upper frontier; \texttt  {SGD} defines the unconstrained lower reference. All projection methods trained with full normalization (Section~\ref {sec:results_rq2}) exceed SGD but fall short of Adam. }}{20}{figure.caption.18}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:hn_cifar10}{{1}{20}{\textbf {Split-CIFAR10 hypernetwork (5 tasks, 50 epochs per task, AdamW first-task initialisation at $10^{-3}$).} Left: average accuracy (bars show mean over seeds; circles show individual seeds). Right: backward transfer. Methods are sorted by average accuracy on the left panel. \texttt {Adam} defines the projection-free upper frontier; \texttt {SGD} defines the unconstrained lower reference. All projection methods trained with full normalization (Section~\ref {sec:results_rq2}) exceed SGD but fall short of Adam}{figure.caption.18}{}}
\@writefile{toc}{\contentsline {paragraph}{{Suffocated regime --- Split-MNIST, $d_h = 8$.}}{20}{paragraph*.19}\protected@file@percent }
\mph@setcol{ii:20}{\mph@nr}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Split-MNIST SH hypernetwork, suffocated regime ($d_h = 8$, 5 tasks, 15 epochs per task, \texttt  {AdamW} first-task initialisation).} Left: average accuracy (bars show mean over seeds; circles show individual seeds; note that several methods completed fewer than three seeds). Right: backward transfer. The dotted line marks \texttt  {Adam}'s mean accuracy ($93.4\%$). Fisher-based projection methods (\texttt  {iFOPNG}, \texttt  {FOPNG}, \texttt  {FNG}) achieve near-zero BWT but much lower accuracy than \texttt  {Adam}, revealing a plasticity failure rather than a retention failure in the extreme compression regime. The Fisher-free \texttt  {OGD} is the best-performing projection method at $86.6\%$. }}{21}{figure.caption.20}\protected@file@percent }
\newlabel{fig:hn_suffocated}{{2}{21}{\textbf {Split-MNIST SH hypernetwork, suffocated regime ($d_h = 8$, 5 tasks, 15 epochs per task, \texttt {AdamW} first-task initialisation).} Left: average accuracy (bars show mean over seeds; circles show individual seeds; note that several methods completed fewer than three seeds). Right: backward transfer. The dotted line marks \texttt {Adam}'s mean accuracy ($93.4\%$). Fisher-based projection methods (\texttt {iFOPNG}, \texttt {FOPNG}, \texttt {FNG}) achieve near-zero BWT but much lower accuracy than \texttt {Adam}, revealing a plasticity failure rather than a retention failure in the extreme compression regime. The Fisher-free \texttt {OGD} is the best-performing projection method at $86.6\%$}{figure.caption.20}{}}
\@writefile{toc}{\contentsline {paragraph}{{Extended task count --- Split-CIFAR100.}}{21}{paragraph*.21}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}{Sub-RQ2: Normalization Resolves the Gradient Pathology}}{21}{subsection.5.2}\protected@file@percent }
\newlabel{sec:results_rq2}{{5.2}{21}{Sub-RQ2: Normalization Resolves the Gradient Pathology}{subsection.5.2}{}}
\@writefile{toc}{\contentsline {paragraph}{{Without normalization.}}{21}{paragraph*.22}\protected@file@percent }
\mph@setcol{ii:21}{\mph@nr}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Projection kernel condition number over training --- \texttt  {iFOPNG} on Split-CIFAR10 HN.} Each line is one seed (legend shows final average accuracy). Task boundaries are marked by vertical dashed lines; gaps indicate early stopping. Left (full normalization): $\log _{10}\kappa (G^\top \hat  {F}G)$ remains bounded within $[10^{1.3},\,10^{3.3}]$ throughout. Right (no normalization): condition number spikes to $10^{10.8}$ at the T2$\to $T3 transition, causing projection failure. Diamond markers indicate end-of-task condition number values. }}{22}{figure.caption.23}\protected@file@percent }
\newlabel{fig:norm_conditioning}{{3}{22}{\textbf {Projection kernel condition number over training --- \texttt {iFOPNG} on Split-CIFAR10 HN.} Each line is one seed (legend shows final average accuracy). Task boundaries are marked by vertical dashed lines; gaps indicate early stopping. Left (full normalization): $\log _{10}\kappa (G^\top \hat {F}G)$ remains bounded within $[10^{1.3},\,10^{3.3}]$ throughout. Right (no normalization): condition number spikes to $10^{10.8}$ at the T2$\to $T3 transition, causing projection failure. Diamond markers indicate end-of-task condition number values}{figure.caption.23}{}}
\@writefile{toc}{\contentsline {paragraph}{{Gradient-only normalization.}}{22}{paragraph*.24}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{{Full normalization.}}{22}{paragraph*.25}\protected@file@percent }
\mph@setcol{ii:22}{\mph@nr}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Normalization ablation --- \texttt  {iFOPNG} on Split-CIFAR10 HN (Sub-RQ2).} Three conditions: no normalization, gradient-only normalization, and full normalization. Left: average accuracy with mean annotated on each bar. Right: backward transfer. Circles show individual seeds; bars show the mean. The dotted line on the left panel marks random-chance performance ($50\%$ for binary per-task classification). }}{23}{figure.caption.26}\protected@file@percent }
\newlabel{fig:norm_ablation}{{4}{23}{\textbf {Normalization ablation --- \texttt {iFOPNG} on Split-CIFAR10 HN (Sub-RQ2).} Three conditions: no normalization, gradient-only normalization, and full normalization. Left: average accuracy with mean annotated on each bar. Right: backward transfer. Circles show individual seeds; bars show the mean. The dotted line on the left panel marks random-chance performance ($50\%$ for binary per-task classification)}{figure.caption.26}{}}
\@writefile{toc}{\contentsline {paragraph}{{Diagnostic: SGD first-task convergence threshold.}}{23}{paragraph*.27}\protected@file@percent }
