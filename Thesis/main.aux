\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Normalization ablation --- \texttt  {iFOPNG} on Split-CIFAR10 HN (Sub-RQ2).} Three conditions: no normalization, gradient-only normalization, and full normalization. Left: average accuracy with mean annotated on each bar. Right: backward transfer. Circles show individual seeds; bars show the mean. The dotted line on the left panel marks random-chance performance ($50\%$ for binary per-task classification). }}{26}{figure.caption.34}\protected@file@percent }
\newlabel{fig:norm_ablation}{{4}{26}{\textbf {Normalization ablation --- \texttt {iFOPNG} on Split-CIFAR10 HN (Sub-RQ2).} Three conditions: no normalization, gradient-only normalization, and full normalization. Left: average accuracy with mean annotated on each bar. Right: backward transfer. Circles show individual seeds; bars show the mean. The dotted line on the left panel marks random-chance performance ($50\%$ for binary per-task classification)}{figure.caption.34}{}}
\@writefile{toc}{\contentsline {paragraph}{{Diagnostic: SGD first-task convergence threshold.}}{26}{paragraph*.35}\protected@file@percent }
