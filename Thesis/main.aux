\mph@setcol{ii:24}{\mph@nr}
\@writefile{toc}{\contentsline {paragraph}{{Without normalization.}}{25}{paragraph*.30}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Projection kernel condition number over training --- \texttt  {iFOPNG} on Split-CIFAR10 HN.} Each line is one seed (legend shows final average accuracy). Task boundaries are marked by vertical dashed lines; gaps indicate early stopping. Left (full normalization): $\log _{10}\kappa (G^\top \hat  {F}G)$ remains bounded within $[10^{1.3},\,10^{3.3}]$ throughout. Right (no normalization): condition number spikes to $10^{10.8}$ at the T2$\to $T3 transition, causing projection failure. Diamond markers indicate end-of-task condition number values. }}{25}{figure.caption.31}\protected@file@percent }
\newlabel{fig:norm_conditioning}{{3}{25}{\textbf {Projection kernel condition number over training --- \texttt {iFOPNG} on Split-CIFAR10 HN.} Each line is one seed (legend shows final average accuracy). Task boundaries are marked by vertical dashed lines; gaps indicate early stopping. Left (full normalization): $\log _{10}\kappa (G^\top \hat {F}G)$ remains bounded within $[10^{1.3},\,10^{3.3}]$ throughout. Right (no normalization): condition number spikes to $10^{10.8}$ at the T2$\to $T3 transition, causing projection failure. Diamond markers indicate end-of-task condition number values}{figure.caption.31}{}}
\@writefile{toc}{\contentsline {paragraph}{{Gradient-only normalization.}}{25}{paragraph*.32}\protected@file@percent }
