\@writefile{toc}{\contentsline {paragraph}{{Standard hypernetwork --- Split-CIFAR10.}}{22}{paragraph*.25}\protected@file@percent }
\mph@setcol{ii:22}{\mph@nr}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Split-CIFAR10 hypernetwork (5 tasks, 50 epochs per task, AdamW first-task initialisation at $10^{-3}$).} Left: average accuracy (bars show mean over seeds; circles show individual seeds). Right: backward transfer. Methods are sorted by average accuracy on the left panel. \texttt  {Adam} defines the projection-free upper frontier; \texttt  {SGD} defines the unconstrained lower reference. All projection methods trained with full normalization (Section~\ref {sec:results_rq2}) exceed SGD but fall short of Adam. }}{23}{figure.caption.26}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:hn_cifar10}{{1}{23}{\textbf {Split-CIFAR10 hypernetwork (5 tasks, 50 epochs per task, AdamW first-task initialisation at $10^{-3}$).} Left: average accuracy (bars show mean over seeds; circles show individual seeds). Right: backward transfer. Methods are sorted by average accuracy on the left panel. \texttt {Adam} defines the projection-free upper frontier; \texttt {SGD} defines the unconstrained lower reference. All projection methods trained with full normalization (Section~\ref {sec:results_rq2}) exceed SGD but fall short of Adam}{figure.caption.26}{}}
\@writefile{toc}{\contentsline {paragraph}{{Suffocated regime --- Split-MNIST, $d_h = 8$.}}{23}{paragraph*.27}\protected@file@percent }
\mph@setcol{ii:23}{\mph@nr}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Split-MNIST SH hypernetwork, suffocated regime ($d_h = 8$, 5 tasks, 15 epochs per task, \texttt  {AdamW} first-task initialisation).} Left: average accuracy (bars show mean over seeds; circles show individual seeds; note that several methods completed fewer than three seeds). Right: backward transfer. The dotted line marks \texttt  {Adam}'s mean accuracy ($93.4\%$). Fisher-based projection methods (\texttt  {iFOPNG}, \texttt  {FOPNG}, \texttt  {FNG}) achieve near-zero BWT but much lower accuracy than \texttt  {Adam}, revealing a plasticity failure rather than a retention failure in the extreme compression regime. The Fisher-free \texttt  {OGD} is the best-performing projection method at $86.6\%$. }}{24}{figure.caption.28}\protected@file@percent }
\newlabel{fig:hn_suffocated}{{2}{24}{\textbf {Split-MNIST SH hypernetwork, suffocated regime ($d_h = 8$, 5 tasks, 15 epochs per task, \texttt {AdamW} first-task initialisation).} Left: average accuracy (bars show mean over seeds; circles show individual seeds; note that several methods completed fewer than three seeds). Right: backward transfer. The dotted line marks \texttt {Adam}'s mean accuracy ($93.4\%$). Fisher-based projection methods (\texttt {iFOPNG}, \texttt {FOPNG}, \texttt {FNG}) achieve near-zero BWT but much lower accuracy than \texttt {Adam}, revealing a plasticity failure rather than a retention failure in the extreme compression regime. The Fisher-free \texttt {OGD} is the best-performing projection method at $86.6\%$}{figure.caption.28}{}}
\@writefile{toc}{\contentsline {paragraph}{{Extended task count --- Split-CIFAR100.}}{24}{paragraph*.29}\protected@file@percent }
