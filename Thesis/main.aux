\mph@setcol{ii:23}{\mph@nr}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {iFOPNG vs.\ FOPNG across seven benchmarks (Sub-RQ3).} Grouped bars show mean average accuracy; circles show individual seeds; error bars show $\pm 1$ standard deviation. The dashed vertical line separates standalone (left) from hypernetwork (right) settings. \texttt  {iFOPNG} uses the combined metric $F_c = \hat  {F}_\mathrm  {new} + \hat  {F}_\mathrm  {old}$; \texttt  {FOPNG} uses only $\hat  {F}_\mathrm  {new}$. }}{24}{figure.caption.28}\protected@file@percent }
\newlabel{fig:ifopng_comparison}{{5}{24}{\textbf {iFOPNG vs.\ FOPNG across seven benchmarks (Sub-RQ3).} Grouped bars show mean average accuracy; circles show individual seeds; error bars show $\pm 1$ standard deviation. The dashed vertical line separates standalone (left) from hypernetwork (right) settings. \texttt {iFOPNG} uses the combined metric $F_c = \hat {F}_\mathrm {new} + \hat {F}_\mathrm {old}$; \texttt {FOPNG} uses only $\hat {F}_\mathrm {new}$}{figure.caption.28}{}}
