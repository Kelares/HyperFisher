    urldate = {2026-02-23},
    date = {2017-03-28},
    year = {2017},
    langid = {english},
    eprinttype = {arxiv},
    eprint = {1612.00796 [cs]},
    keywords = {Computer Science - Machine Learning, Computer Science - Artificial Intelligence, Statistics - Machine Learning},
    file = {PDF:/home/kelares/Zotero/storage/GCFC8DUB/Kirkpatrick et al. - 2017 - Overcoming catastrophic forgetting in neural networks.pdf:application/pdf},
}

@misc{fuente_prototype_2025,
    title = {Prototype Augmented Hypernetworks for Continual Learning},
    url = {http://arxiv.org/abs/2505.07450},
    doi = {10.48550/arXiv.2505.07450},
    abstract = {Continual learning ({CL}) aims to learn a sequence of tasks without forgetting prior knowledge, but gradient updates for a new task often overwrite the weights learned earlier, causing catastrophic forgetting ({CF}). We propose {PrototypeAugmented} Hypernetworks (P {AH}), a framework where a single hypernetwork, conditioned on learnable task prototypes, dynamically generates task-specific classifier heads on demand. To mitigate forgetting, P {AH} combines crossentropy with dual distillation losses, one to align logits and another to align prototypes, ensuring stable feature representations across tasks. Evaluations on Split-{CIFAR}100 and {TinyImageNet} demonstrate that {PAH} achieves state-ofthe-art performance, reaching 74.5\% and 63.7\% accuracy with only 1.7\% and 4.4\% forgetting, respectively, surpassing prior methods without storing samples or heads.},
